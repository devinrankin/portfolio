---
import FormattedDate from "../components/FormattedDate.astro";
import Tags from "../components/Tags.astro";
import "../styles/global.css";
import type { CollectionEntry } from "astro:content";

type Props = CollectionEntry<"blog">["data"];

const { title, description, date, tags, slug } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="icons/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="keywords" content={tags} />
    <meta name="author" content="Devin Rankin" />
    <title>devin/blog/{slug}</title>
  </head>
  <body>
    <nav><a href="/feed">&lt;-- back</a></nav>
    <header class="space-y-1 mt-8">
      <FormattedDate date={date} />
      <p>{title}</p>
      <Tags tags={tags} />
      <p class="text-sm">{description}</p>
    </header>

    <hr class="my-4 border-1 border-foreground"/>
    <slot />
  </body>
</html>
