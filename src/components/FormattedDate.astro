---
interface Props {
  class?: string;
  date: Date;
}

const { class: className, date } = Astro.props;
---

<time datetime={date.toISOString()} class="text-foreground-dull text-xs block ">
  {
    date.toLocaleDateString('ja-jp', {
      year: 'numeric',
      month: 'numeric',
      day: 'numeric'
    }).replace(/\//g, '-')
  }
</time>